{
  "name": "@buka/error-codes",
  "version": "1.0.2",
  "description": "The error codes management tool library maintained by Buka Inc.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "is-ci || husky",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:update": "jest --updateSnapshot"
  },
  "keywords": [
    "buka",
    "buka-inc",
    "error",
    "code",
    "codes",
    "error-code",
    "error-codes"
  ],
  "author": "Val.istar.Guo <val.istar.guo@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "homepage": "https://github.com/buka-inc/npm.error-codes#readme",
  "bugs": {
    "url": "https://github.com/buka-inc/npm.error-codes/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/buka-inc/npm.error-codes"
  },
  "devDependencies": {
    "@buka/eslint-config": "^3.0.3",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@jest/globals": "^30.2.0",
    "@jest/types": "^30.2.0",
    "@types/node": "^20.19.30",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ts-custom-error": "^3.3.1"
  }
}
